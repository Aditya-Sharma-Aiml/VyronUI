# MongoDB Connection
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/vyron-ui

# API Keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# JWT Secret (Generate a random string)
JWT_SECRET=your_jwt_secret_here

# Port (Render automatically assigns PORT env variable)
PORT=8000

# Client URL (Frontend domain)
CLIENT_URL=https://your-frontend-url.onrender.com  # Update with actual frontend URL for production

# Environment
NODE_ENV=development
RENDER=false  # Set to "true" when deploying on Render
